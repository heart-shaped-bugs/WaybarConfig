// -*- mode: jsonc -*-
{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    //"height": 10, // Waybar height (to be removed for auto height)
    //"width": 1590, // Waybar width
    //"margin-top": 10,
    //"margin-left":10,
    //"margin-right":10,
    //"margin-bottom": 10,
    // Choose the order of the modules
    "modules-left": [
	//"custom/poweroff",
    "group/power",
    "group/apps",
    "custom/playpause",
    //"custom/appmenu",
    "niri/workspaces",
    "cava",
	"hyprland/window"
    //"tray"
    ],
    "modules-center": [
	"hyprland/workspaces"
    //"niri/window"
    ],
    "modules-right": [
        "network",
        //"idle_inhibitor",
        "pulseaudio",
        "backlight",
        //"battery",
	//"custom/weather",
        //"wlr/taskbar",
        //"group/apps",
        //"network",
        //"group/stats",
        "battery",
        "clock"
    ], 
   "hyprland/workspaces": {
	"format": "{name}",
	"format-icons": {
		"active": "",
		"default": ""
	},
       //"persistent-workspaces": {
       //      "*": 5, // 5 workspaces by default on every monitor
       //      "HDMI-A-1": 5 // but only three on HDMI-A-1
       //}
   },
   "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d-%m-%Y}",
        "format": "{:%H:%M:%S}",
        "interval": 1
    },
   "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["", "", "", "", "", "", "", "", ""],
        "tooltip": false
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 20,
            "critical": 5
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        "tooltip-format": "{power} W, {timeTo}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󱈏"]
    },
    "network": {
        //"interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} {signalStrength}% {icon}",
        "format-icons": ["󰤟", "󰤢", "󰤥", "󰤨"],
        "interval": 1,
        "format-ethernet": "{ipaddr}/{cidr} ",
        //"tooltip-format": "{ifname} via {gwaddr} ",
        "tooltip-format": "{essid}: {bandwidthUpBits}⇡ {bandwidthDownBits}⇣",
        //"on-click": "iwctl station wlan0 get-networks"
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}: {essid}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": "MUTE 󰝟",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pactl set-sink-mute 0 toggle",
        "tooltip": false
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "",
            "default": "🎜"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    //"custom/weather": {
    //    "exec": "${HOME}/.config/waybar/scripts/get_weather.sh Fredericton+Canada",
    //    "return-type": "json",
    //    "format": "{}",
    //    "tooltip": true,
    //    "interval": 3600
    //},
    "custom/poweroff": {
	    "format": "⏻",
        "on-click": "exec ${HOME}/.config/waybar/scripts/powermenu",
        "tooltip-format": "Power Menu",
        "tooltip": true
    },
    "custom/power": {
        "format" : "⏻ ",
        "tooltip": false,
        "menu": "on-click",
        "menu-file": "~/.config/waybar/power_menu.xml",
        "menu-actions": {
            "shutdown": "shutdown",
            "reboot": "reboot",
            "suspend": "systemctl suspend",
            "hibernate": "systemctl hibernate",
        },
    },
    "cava": {
        "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
        "framerate": 30,
        "autosens": 1,
        "sensitivity": 100,
        "bars": 14,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "hide_on_silence": false,
        // "format_silent": "quiet",
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    },
    "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "",
        "deactivated": ""
    }
    },
    "custom/powerbutton": {
        "format": "⏻",
        "on-click": "poweroff",
        "tooltip-format": "Power Off"
    },
    "custom/reboot": {
        "format": "󰜉",
        "on-click": "reboot",
        "tooltip-format": "Reboot"
    },
    "custom/suspend": {
        "format": "",
        "on-click": "systemctl suspend",
        "tooltip-format": "Suspend"
    },
    "custom/lock": {
        "format": "󰍁",
        "on-click": "hyprlock",
        "tooltip-format": "Lock"
    },
    "custom/idlekiller": {
        "format": "",
        "on-click": "pkill hypridle || hypridle",
        "tooltip-format": "Inhibit Idle"
    },
    "group/power": {
        "modules": [
            "custom/powerbutton",
            "custom/reboot",
            //"custom/suspend",
            //"custom/lock",
            //"custom/idlekiller",
            "user",
        ],
        "orientation": "inherit", //"inherit"
        "drawer": {
            "transition-duration": 500
        }
    },
    "group/stats": {
        "modules": [
            "battery",
            "group/brightness",
            "group/audio"
        ],
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 750,
            "transition-left-to-right": false
        }
    },
    "custom/appmenu": {
        "format": "󰀻",
        //"on-click": "rofi -show drun -theme appmenu.rasi",
        "tooltip": false
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "on-click": "activate",
        "on-click-right": "close"
    },
    "group/apps": {
        "modules" : [
            "custom/appmenu",
            "wlr/taskbar"
        ],
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": false
        }
    },
    "pulseaudio/slider": {
        "min": 0,
        "max": 100,
        "orientation": "horizontal"
    },
    "backlight/slider": {
        "min": 0,
        "max": 10, //cause more than 10 disable brightnessctl (idk why)
        "orientation": "horizontal", //horizontal
    },
    "group/audio": {
        "modules" : [
            "pulseaudio",
            "pulseaudio/slider"
        ],
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": true
        }
    },
    "group/brightness": {
        "modules" : [
            "backlight",
            "backlight/slider"
        ],
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": true
        }
    },
    "user": {
        "format": "{work_H}:{work_M}:{work_S} ↑",
        "interval": 60,
    },
    "niri/window": {
        "tooltip": false,
        "format": "{title}"
    },
    "custom/playpause": {
        "format": "󰐎",
        "on-click": "playerctl play-pause",
        "tooltip": false
    }
}
